#!/bin/bash
set -euo pipefail

VERSION="0.1.0"
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
PROFILE_TPL="$SCRIPT_DIR/profiles/macos.sb.tpl"

# --- Defaults ---
NO_NETWORK=false
DRY_RUN=false
VERBOSE=false
AUTO_APPLY=false
AUTO_DISCARD=false
SECRETS_FILES=()
SECRETS_ACTIVE=false
SECRET_LOG=true
EXTRA_ALLOW=()
EXTRA_RW=()
EXTRA_DENY=()
ALLOWED_DOMAINS=()
BLOCKED_DOMAINS=()
ON_EXIT=""
ENV_OVERRIDES=()
SHELL_ONLY=false

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# --- Functions ---

usage() {
  cat <<EOF
${BOLD}parcai${RESET} v${VERSION} — Lightweight shell isolation for AI agents

${BOLD}Usage:${RESET}
  parcai [options]

${BOLD}Options:${RESET}
  --allow <path>     Additional path to whitelist (read-only). Repeatable.
  --rw <path>        Additional path to whitelist (read-write). Repeatable.
  --deny <path>      Deny all file access to <path>. Repeatable.
  --no-network       Deny all network access inside the sandbox.
  --secrets <file>   Mask secrets from <file> (repeatable). Default: .env if it exists.
  --secret-log       Write proxy audit log to session directory.
  --apply            Auto-apply changes on exit (skip confirmation).
  --discard          Auto-discard changes on exit (skip confirmation).
  --config <file>    Use a specific config file (default: .parcai.json).
  --shell            Launch a plain shell instead of claude.
  --dry-run          Print the sandbox config without executing.
  --verbose          Show sandbox setup details.
  --help             Show help.
  --version          Show version.

${BOLD}Config file:${RESET}
  Place a ${BOLD}.parcai.json${RESET} in your project root to set defaults.
  Run ${BOLD}parcai init${RESET} to generate a starter config.
  CLI flags override config file values.
EOF
}

die() {
  echo -e "${RED}error:${RESET} $1" >&2
  exit 1
}

info() {
  echo -e "${CYAN}parcai:${RESET} $1"
}

warn() {
  echo -e "${YELLOW}parcai:${RESET} $1"
}

# --- Configuration File ---

CONFIG_FILE=".parcai.json"

# Minimal JSON value extractor (no jq dependency).
# Handles: strings, booleans, numbers. Does NOT handle nested objects.
json_value() {
  local json="$1" key="$2"
  # Match "key": "value" or "key": value (bool/number)
  local val
  val=$(echo "$json" | sed -n 's/.*"'"$key"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
  if [[ -n "$val" ]]; then
    echo "$val"
    return
  fi
  # Try non-string value (bool, number, null)
  val=$(echo "$json" | sed -n 's/.*"'"$key"'"[[:space:]]*:[[:space:]]*\([^,}]*\).*/\1/p' | head -1 | tr -d '[:space:]')
  echo "$val"
}

# Extract a JSON array of strings: "key": ["a", "b"] → one per line
# Handles multi-line arrays by flattening the JSON first
json_array() {
  local json="$1" key="$2"
  # Flatten to single line, collapse whitespace
  local flat
  flat=$(echo "$json" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g')
  # Extract the array content between [ and ]
  local arr
  arr=$(echo "$flat" | sed -n 's/.*"'"$key"'"[[:space:]]*:[[:space:]]*\[\([^]]*\)\].*/\1/p' | head -1)
  [[ -z "$arr" ]] && return
  # Extract quoted strings
  echo "$arr" | grep -oE '"[^"]*"' | tr -d '"'
}

load_config() {
  local config_path="$1"

  if [[ ! -f "$config_path" ]]; then
    return 0
  fi

  $VERBOSE && info "loading config: $config_path"

  local json
  json=$(cat "$config_path")

  # network
  local net_val
  net_val=$(json_value "$json" "network")
  if [[ "$net_val" == "false" ]]; then
    NO_NETWORK=true
  fi

  # secrets — can be a string or array in config
  if [[ ${#SECRETS_FILES[@]} -eq 0 ]]; then
    # Try array first: "secrets": [".env", ".env.prod"]
    while IFS= read -r sf; do
      [[ -z "$sf" ]] && continue
      SECRETS_FILES+=("$sf")
    done < <(json_array "$json" "secrets")
    # Fall back to single string: "secrets": ".env"
    if [[ ${#SECRETS_FILES[@]} -eq 0 ]]; then
      local sec_val
      sec_val=$(json_value "$json" "secrets")
      if [[ -n "$sec_val" && "$sec_val" != "null" ]]; then
        SECRETS_FILES+=("$sec_val")
      fi
    fi
  fi

  # secret_log
  local sl_val
  sl_val=$(json_value "$json" "secret_log")
  if [[ "$sl_val" == "true" ]]; then
    SECRET_LOG=true
  fi

  # on_exit
  local oe_val
  oe_val=$(json_value "$json" "on_exit")
  if [[ -n "$oe_val" && "$oe_val" != "null" && -z "$ON_EXIT" ]]; then
    ON_EXIT="$oe_val"
    case "$ON_EXIT" in
      apply)   AUTO_APPLY=true ;;
      discard) AUTO_DISCARD=true ;;
    esac
  fi

  # verbose
  local v_val
  v_val=$(json_value "$json" "verbose")
  if [[ "$v_val" == "true" ]]; then
    VERBOSE=true
  fi

  # allow (array of paths)
  while IFS= read -r p; do
    [[ -z "$p" ]] && continue
    EXTRA_ALLOW+=("$p")
  done < <(json_array "$json" "allow")

  # rw (array of paths)
  while IFS= read -r p; do
    [[ -z "$p" ]] && continue
    EXTRA_RW+=("$p")
  done < <(json_array "$json" "rw")

  # deny (array of paths)
  while IFS= read -r p; do
    [[ -z "$p" ]] && continue
    EXTRA_DENY+=("$p")
  done < <(json_array "$json" "deny")

  # allowed_domains (array of domain strings)
  while IFS= read -r d; do
    [[ -z "$d" ]] && continue
    ALLOWED_DOMAINS+=("$d")
  done < <(json_array "$json" "allowed_domains")

  # blocked_domains (array of domain strings)
  while IFS= read -r d; do
    [[ -z "$d" ]] && continue
    BLOCKED_DOMAINS+=("$d")
  done < <(json_array "$json" "blocked_domains")

  # env (object of KEY=VALUE overrides — parsed as flat key/value pairs)
  # Supports "env": {"NODE_ENV": "test", "DEBUG": "1"}
  local env_block
  env_block=$(echo "$json" | sed -n '/"env"[[:space:]]*:/,/}/p' | tail -n +1)
  if [[ -n "$env_block" ]]; then
    while IFS= read -r pair; do
      [[ -z "$pair" ]] && continue
      local ekey eval_
      ekey=$(echo "$pair" | sed -n 's/.*"\([^"]*\)"[[:space:]]*:.*/\1/p')
      eval_=$(echo "$pair" | sed -n 's/.*:[[:space:]]*"\([^"]*\)".*/\1/p')
      if [[ -n "$ekey" && -n "$eval_" && "$ekey" != "env" ]]; then
        ENV_OVERRIDES+=("${ekey}=${eval_}")
      fi
    done <<< "$env_block"
  fi
}

generate_default_config() {
  cat <<'CONFIGEOF'
{
  "network": true,
  "secrets": [
    ".env",
    ".env.local",
    ".env.development",
    ".env.development.local",
    ".env.production",
    ".env.production.local",
    ".env.staging",
    ".env.test",
    ".env.test.local",
    ".secrets",
    ".secrets.json",
    "secrets.yaml",
    "secrets.yml",
    ".credentials",
    "credentials.json",
    "service-account.json",
    "service-account-key.json",
    ".npmrc",
    ".pypirc",
    ".netrc",
    ".docker/config.json"
  ],
  "secret_log": true,
  "on_exit": "ask",
  "verbose": false,

  "allow": [],
  "rw": [],
  "deny": [],

  "allowed_domains": [],
  "blocked_domains": [],

  "env": {}
}
CONFIGEOF
}

# --- Platform Check ---

check_platform() {
  [[ "$(uname -s)" == "Darwin" ]] || die "parcai requires macOS (found: $(uname -s))"
}

# --- Environment & Domain Injection ---

# Write env overrides and domain-filter env vars into a shell config file.
# Called to write env overrides into .zshenv inside the clone.
inject_env_into_shell_config() {
  local target_file="$1"

  # Env overrides from config
  for entry in "${ENV_OVERRIDES[@]+"${ENV_OVERRIDES[@]}"}"; do
    local key="${entry%%=*}"
    local val="${entry#*=}"
    echo "export ${key}=\"${val}\"" >> "$target_file"
  done

  # Domain filtering — exported as env vars for the proxy or iptables wrapper
  if [[ ${#ALLOWED_DOMAINS[@]} -gt 0 ]]; then
    local joined
    joined=$(IFS=,; echo "${ALLOWED_DOMAINS[*]}")
    echo "export PARCAI_ALLOWED_DOMAINS=\"${joined}\"" >> "$target_file"
  fi

  if [[ ${#BLOCKED_DOMAINS[@]} -gt 0 ]]; then
    local joined
    joined=$(IFS=,; echo "${BLOCKED_DOMAINS[*]}")
    echo "export PARCAI_BLOCKED_DOMAINS=\"${joined}\"" >> "$target_file"
  fi
}


# --- Session Persistence ---

session_dir() {
  local cwd="$1"
  local hash
  hash=$(printf '%s' "$cwd" | sha256sum 2>/dev/null || printf '%s' "$cwd" | shasum -a 256 2>/dev/null)
  hash="${hash%% *}"
  hash="${hash:0:20}"
  echo "$HOME/.parcai/sessions/$hash"
}

CLAUDE_HOME="$HOME/.parcai/claude-home"

persist_claude_config() {
  local clone="$1"

  mkdir -p "$CLAUDE_HOME"

  # Sync clone's .claude/ → persistent claude-home/.claude/
  if [[ -d "$clone/.claude" ]]; then
    mkdir -p "$CLAUDE_HOME/.claude"
    rsync -rl --delete \
      --exclude='projects/' --exclude='*.log' --exclude='debug/' \
      --exclude='file-history/' --exclude='cache/' --exclude='downloads/' \
      "$clone/.claude/" "$CLAUDE_HOME/.claude/"
  fi

  # Sync clone's .claude.json → persistent claude-home/
  if [[ -f "$clone/.claude.json" ]]; then
    cp "$clone/.claude.json" "$CLAUDE_HOME/.claude.json"
  fi

  # Sync clone's Library/Application Support/claude/ → persistent claude-home/
  if [[ -d "$clone/Library/Application Support/claude" ]]; then
    mkdir -p "$CLAUDE_HOME/Library/Application Support/claude"
    rsync -rl --delete \
      "$clone/Library/Application Support/claude/" "$CLAUDE_HOME/Library/Application Support/claude/"
  fi
}

inject_claude_config() {
  local clone="$1"

  # Restore persistent claude-home → clone (if previous session exists)
  if [[ -d "$CLAUDE_HOME/.claude" ]]; then
    mkdir -p "$clone/.claude"
    cp -r "$CLAUDE_HOME/.claude/." "$clone/.claude/"
  fi

  if [[ -f "$CLAUDE_HOME/.claude.json" ]]; then
    cp "$CLAUDE_HOME/.claude.json" "$clone/.claude.json"
  fi

  if [[ -d "$CLAUDE_HOME/Library/Application Support/claude" ]]; then
    mkdir -p "$clone/Library/Application Support/claude"
    cp -r "$CLAUDE_HOME/Library/Application Support/claude/." "$clone/Library/Application Support/claude/"
  fi
  # First run: nothing exists in claude-home — Claude starts from scratch
}

# --- Secret Masking ---

generate_fake_token() {
  local key_name="$1"
  local normalized
  normalized=$(echo "$key_name" | tr '[:upper:]' '[:lower:]' | tr -c '[:alnum:]' '_' | sed 's/__*/_/g; s/^_//; s/_$//')
  local hex
  hex=$(head -c 4 /dev/urandom | od -An -tx1 | tr -d ' \n')
  echo "fake_parcai_${normalized}_${hex}"
}

# Setup secrets from one or more files.
# Generates a single vault.json and replaces each source file in the clone with its fake version.
# Usage: setup_secrets <clone_dir> <work_dir> <file1> [file2] ...
setup_secrets() {
  local clone="$1"
  local work_dir="$2"
  shift 2
  local secrets_files=("$@")

  local vault_file="$work_dir/vault.json"
  echo "{" > "$vault_file"

  local first=true

  for secrets_file in "${secrets_files[@]}"; do
    [[ -f "$secrets_file" ]] || die "secrets file not found: $secrets_file"

    local fake_file="$work_dir/fake_$(basename "$secrets_file")"
    : > "$fake_file"

    while IFS= read -r line || [[ -n "$line" ]]; do
      # Skip comments and empty lines
      [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
      # Parse KEY=VALUE
      if [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
        local key="${BASH_REMATCH[1]}"
        local value="${BASH_REMATCH[2]}"
        # Strip surrounding quotes
        value="${value#\"}"
        value="${value%\"}"
        value="${value#\'}"
        value="${value%\'}"

        # Skip empty values
        [[ -z "$value" ]] && { echo "${key}=" >> "$fake_file"; continue; }

        # Skip values too short or too common to mask safely
        # (they would cause false-positive replacements in API responses)
        if [[ ${#value} -lt 8 ]] || [[ "$value" =~ ^(true|false|yes|no|on|off|null|none|verbose|debug|info|warn|error|[0-9]+)$ ]]; then
          echo "${key}=${value}" >> "$fake_file"
          continue
        fi

        local fake_token
        fake_token=$(generate_fake_token "$key")

        if ! $first; then
          echo "," >> "$vault_file"
        fi
        first=false
        printf '  "%s": {"real": "%s", "key": "%s"}' "$fake_token" "$value" "$key" >> "$vault_file"

        echo "${key}=${fake_token}" >> "$fake_file"
      else
        # Preserve non-KEY=VALUE lines (comments, blank lines) as-is
        echo "$line" >> "$fake_file"
      fi
    done < "$secrets_file"

    # Replace the file in the clone with the fake version
    cp "$fake_file" "$clone/$secrets_file"
    info "masked $(basename "$secrets_file") ($(grep -c 'fake_parcai' "$fake_file" 2>/dev/null || echo 0) secrets)" >&2
  done

  echo "" >> "$vault_file"
  echo "}" >> "$vault_file"

  echo "$vault_file"
}

# --- macOS Backend ---

check_macos() {
  command -v sandbox-exec >/dev/null 2>&1 || die "sandbox-exec not found"
}

check_apfs() {
  local cwd="$1"
  local fstype
  fstype=$(diskutil info "$(df "$cwd" | tail -1 | awk '{print $1}')" 2>/dev/null | grep "Type (Bundle)" | awk '{print $NF}')
  if [[ "$fstype" != "apfs" ]]; then
    warn "filesystem is not APFS — clone will be a full copy (slower)"
    return 1
  fi
  return 0
}

create_clone_macos() {
  local src="$1"
  local dst="$2"

  if check_apfs "$src" 2>/dev/null; then
    cp -c -R "$src" "$dst" 2>/dev/null && return 0
  fi
  cp -R "$src" "$dst"
}

generate_profile() {
  local clone="$1"
  local home="$2"
  local profile

  profile=$(cat "$PROFILE_TPL")

  # Substitute placeholders
  profile="${profile//\{\{CLONE\}\}/$clone}"
  profile="${profile//\{\{HOME\}\}/$home}"

  # Claude binary — resolve symlinks to find the real path for exec
  if ! $SHELL_ONLY; then
    local claude_bin
    claude_bin="$(command -v claude 2>/dev/null)" || die "claude not found in PATH"
    local claude_real
    claude_real="$(readlink -f "$claude_bin" 2>/dev/null || realpath "$claude_bin" 2>/dev/null || echo "$claude_bin")"

    profile="${profile//\{\{CLAUDE_EXEC_RULE\}\}/  (literal \"$claude_real\")}"
  else
    profile="${profile//\{\{CLAUDE_EXEC_RULE\}\}/}"
  fi

  # Network policy
  if $NO_NETWORK; then
    profile="${profile//\{\{NETWORK_RULE\}\}/denied (--no-network)}"
    profile="${profile//\{\{NETWORK_POLICY\}\}/(deny network*)}"
  else
    profile="${profile//\{\{NETWORK_RULE\}\}/allowed (default)}"
    profile="${profile//\{\{NETWORK_POLICY\}\}/(allow network*)}"
  fi

  # Proxy loopback rule
  if $SECRETS_ACTIVE && [[ -n "${PROXY_PORT:-}" ]]; then
    local loopback_rule
    loopback_rule="(allow network-outbound (local tcp \"*:${PROXY_PORT}\"))"
    profile="${profile//\{\{PROXY_LOOPBACK_RULE\}\}/$loopback_rule}"
  else
    profile="${profile//\{\{PROXY_LOOPBACK_RULE\}\}/}"
  fi

  # Extra read-only paths
  for path in "${EXTRA_ALLOW[@]+"${EXTRA_ALLOW[@]}"}"; do
    local resolved
    resolved="$(cd "$path" 2>/dev/null && pwd)" || die "path not found: $path"
    profile+=$'\n'"(allow file-read* (subpath \"$resolved\"))"
  done

  # Extra read-write paths
  for path in "${EXTRA_RW[@]+"${EXTRA_RW[@]}"}"; do
    local resolved
    resolved="$(cd "$path" 2>/dev/null && pwd)" || die "path not found: $path"
    profile+=$'\n'"(allow file-read* file-write* (subpath \"$resolved\"))"
  done

  # Deny paths
  for path in "${EXTRA_DENY[@]+"${EXTRA_DENY[@]}"}"; do
    local resolved
    resolved="$(cd "$path" 2>/dev/null && pwd)" || die "deny path not found: $path"
    profile+=$'\n'"(deny file-read* file-write* (subpath \"$resolved\"))"
  done

  echo "$profile"
}

run_macos() {
  local cwd="$1"
  local sess_dir="$2"

  check_macos

  local project_name
  project_name="$(basename "$cwd")"

  # Create clone (resolve symlinks — macOS /tmp -> /private/tmp)
  local clone_parent
  clone_parent="$(mktemp -d)"
  clone_parent="$(cd "$clone_parent" && pwd -P)"
  CLONE_DIR="$clone_parent/$project_name"

  info "cloning project (APFS copy-on-write)..."
  create_clone_macos "$cwd" "$CLONE_DIR"
  info "clone: $CLONE_DIR"

  # Inject Claude config
  if [[ -d "$CLAUDE_HOME/.claude" ]]; then
    info "restoring Claude config from $CLAUDE_HOME"
  else
    info "first launch — Claude will start with a fresh config"
  fi
  inject_claude_config "$CLONE_DIR"

  # Setup secrets if any files to mask
  local proxy_pid=""
  if [[ ${#SECRETS_FILES[@]} -gt 0 ]]; then
    local proxy_bin="$SCRIPT_DIR/proxy/parcai-proxy"
    if [[ -x "$proxy_bin" ]]; then
      local work_dir
      work_dir="$(mktemp -d)"

      # Backup originals before masking (so we can restore on proxy failure)
      for sf in "${SECRETS_FILES[@]}"; do
        [[ -f "$CLONE_DIR/$sf" ]] && cp "$CLONE_DIR/$sf" "$work_dir/backup_$(basename "$sf")"
      done

      local vault_file
      vault_file=$(setup_secrets "$CLONE_DIR" "$work_dir" "${SECRETS_FILES[@]}")

      # Start proxy (it prints PORT=<N> and PID=<N> then closes stdout)
      info "starting secret masking proxy..."
      local proxy_args=("start" "--port" "0" "--vault" "$vault_file")
      if $SECRET_LOG; then
        proxy_args+=("--log" "$sess_dir/proxy.log")
      fi
      if [[ ${#ALLOWED_DOMAINS[@]} -gt 0 ]]; then
        local joined
        joined=$(IFS=,; echo "${ALLOWED_DOMAINS[*]}")
        proxy_args+=("--allowed-domains" "$joined")
      fi
      if [[ ${#BLOCKED_DOMAINS[@]} -gt 0 ]]; then
        local joined
        joined=$(IFS=,; echo "${BLOCKED_DOMAINS[*]}")
        proxy_args+=("--blocked-domains" "$joined")
      fi
      local proxy_output
      proxy_output=$("$proxy_bin" "${proxy_args[@]}" 2>/dev/null)
      PROXY_PORT=$(echo "$proxy_output" | grep -oE 'PORT=[0-9]+' | cut -d= -f2)
      proxy_pid=$(echo "$proxy_output" | grep -oE 'PID=[0-9]+' | cut -d= -f2)

      if [[ -z "$PROXY_PORT" ]]; then
        warn "failed to start proxy — restoring original secrets files"
        # Restore originals so the agent doesn't see broken fake tokens
        for sf in "${SECRETS_FILES[@]}"; do
          local backup="$work_dir/backup_$(basename "$sf")"
          [[ -f "$backup" ]] && cp "$backup" "$CLONE_DIR/$sf"
        done
        SECRETS_ACTIVE=false
      else
        SECRETS_ACTIVE=true
        info "proxy listening on 127.0.0.1:$PROXY_PORT (PID $proxy_pid)"
      fi
    else
      warn "parcai-proxy not found — --secrets requires proxy/parcai-proxy"
      warn "continuing without secret masking"
      SECRETS_ACTIVE=false
    fi
  fi

  # Resolve claude binary path (needed for PATH and .zshrc)
  local claude_bin_dir=""
  if ! $SHELL_ONLY; then
    local claude_bin
    claude_bin="$(command -v claude 2>/dev/null)" || die "claude not found in PATH"
    claude_bin_dir="$(dirname "$claude_bin")"

    # Create ~/.local/bin/claude symlink in clone so Claude finds itself at $HOME/.local/bin
    # (Claude checks installMethod=native and expects ~/.local/bin in PATH)
    mkdir -p "$CLONE_DIR/.local/bin"
    ln -sf "$claude_bin" "$CLONE_DIR/.local/bin/claude"
  fi

  # Create minimal shell config in the clone
  cat > "$CLONE_DIR/.zshenv" 2>/dev/null <<SHELLEOF || true
# parcai: minimal env
export PATH="/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin:/opt/homebrew/bin${claude_bin_dir:+:$claude_bin_dir}:\$HOME/.local/bin"
SHELLEOF

  # Inject env overrides and domain config
  inject_env_into_shell_config "$CLONE_DIR/.zshenv"

  # Inject proxy env vars if secrets are active
  if $SECRETS_ACTIVE && [[ -n "${PROXY_PORT:-}" ]]; then
    cat >> "$CLONE_DIR/.zshenv" <<PROXYEOF
export HTTPS_PROXY=http://127.0.0.1:${PROXY_PORT}
export HTTP_PROXY=http://127.0.0.1:${PROXY_PORT}
export NODE_EXTRA_CA_CERTS=/tmp/parcai-proxy-ca.crt
PROXYEOF
  fi

  if $SHELL_ONLY; then
    cat > "$CLONE_DIR/.zshrc" 2>/dev/null <<'SHELLEOF' || true
# parcai: sandboxed shell
PS1='[parcai] %1~ %# '
SHELLEOF
  else
    cat > "$CLONE_DIR/.zshrc" 2>/dev/null <<SHELLEOF || true
# parcai: launch claude then exit
PS1='[parcai] %1~ %# '
"$claude_bin_dir/claude" --dangerously-skip-permissions
exit \$?
SHELLEOF
  fi

  # Generate sandbox profile
  info "generating sandbox profile..."
  SANDBOX_PROFILE="$(mktemp /tmp/parcai-XXXXXXXX).sb"
  generate_profile "$CLONE_DIR" "$HOME" > "$SANDBOX_PROFILE"
  info "sandbox profile: $SANDBOX_PROFILE"
  info "network: $( $NO_NETWORK && echo 'denied' || echo 'allowed' )"
  $SECRETS_ACTIVE && info "secrets: active (proxy port ${PROXY_PORT:-n/a})"

  if $DRY_RUN; then
    echo ""
    echo -e "${BOLD}--- Sandbox Profile ---${RESET}"
    cat "$SANDBOX_PROFILE"
    echo ""
    echo -e "${BOLD}--- Clone Directory ---${RESET}"
    echo "$CLONE_DIR"
    cleanup_macos "$proxy_pid"
    exit 0
  fi

  # Launch sandbox
  if $SHELL_ONLY; then
    info "entering isolated shell..."
    echo -e "${GREEN}${BOLD}[parcai]${RESET} only ${BOLD}$project_name/${RESET} is accessible. Type ${BOLD}exit${RESET} to leave."
  else
    info "launching claude in isolated sandbox..."
    echo -e "${GREEN}${BOLD}[parcai]${RESET} only ${BOLD}$project_name/${RESET} is accessible."
  fi
  $NO_NETWORK && echo -e "${YELLOW}[parcai]${RESET} network access is ${BOLD}disabled${RESET}"
  $SECRETS_ACTIVE && echo -e "${YELLOW}[parcai]${RESET} secrets masked via proxy (${#SECRETS_FILES[@]} file(s))"
  echo ""

  set +e
  pushd "$CLONE_DIR" > /dev/null 2>&1
  PARCAI=1 \
  PARCAI_BACKEND=sandbox-exec \
  PARCAI_HOST_CWD="$(basename "$cwd")" \
  HOME="$CLONE_DIR" \
  ZDOTDIR="$CLONE_DIR" \
  sandbox-exec -f "$SANDBOX_PROFILE" /bin/zsh -i
  EXIT_CODE=$?
  popd > /dev/null 2>&1
  set -e

  echo ""

  # Persist Claude config
  info "persisting Claude config to $CLAUDE_HOME"
  persist_claude_config "$CLONE_DIR"

  # Handle project changes
  handle_changes "$CLONE_DIR" "$cwd"

  # Cleanup
  info "cleaning up sandbox..."
  cleanup_macos "$proxy_pid"

  return $EXIT_CODE
}

cleanup_macos() {
  local proxy_pid="${1:-}"

  if [[ -n "$proxy_pid" ]]; then
    kill "$proxy_pid" 2>/dev/null || true
  fi
  if [[ -n "${SANDBOX_PROFILE:-}" && -f "${SANDBOX_PROFILE:-}" ]]; then
    rm -f "$SANDBOX_PROFILE"
  fi
  if [[ -n "${CLONE_DIR:-}" && -d "${CLONE_DIR:-}" ]]; then
    rm -rf "$CLONE_DIR"
  fi
}

# --- Change Handling ---

diff_changes() {
  local clone="$1"
  local original="$2"

  local exclude_args=(
    --exclude='.zshenv' --exclude='.zshrc' --exclude='.zsh_history'
    --exclude='.claude/' --exclude='.cache/' --exclude='.config/'
    --exclude='.local/' --exclude='Library/' --exclude='.claude.json'
    --exclude='Applications/'
  )
  if $SECRETS_ACTIVE; then
    for sf in "${SECRETS_FILES[@]}"; do
      exclude_args+=(--exclude="$sf")
    done
  fi

  local changes
  changes=$(rsync -rlpn --delete --out-format="%i %n" \
    "${exclude_args[@]}" \
    "$clone/" "$original/" 2>/dev/null | head -50)

  if [[ -z "$changes" ]]; then
    return 1
  fi

  echo "$changes" | while IFS= read -r line; do
    local flags="${line%% *}"
    local file="${line#* }"
    if [[ "$flags" == *"deleting"* ]]; then
      echo -e "  ${RED}D${RESET}  $file"
    elif [[ "$flags" == *"f+++"* ]]; then
      echo -e "  ${GREEN}A${RESET}  $file"
    else
      echo -e "  ${YELLOW}M${RESET}  $file"
    fi
  done

  return 0
}

apply_changes() {
  local clone="$1"
  local original="$2"

  local exclude_args=(
    --exclude='.zshenv' --exclude='.zshrc' --exclude='.zsh_history'
    --exclude='.claude/' --exclude='.cache/' --exclude='.config/'
    --exclude='.local/' --exclude='Library/' --exclude='.claude.json'
    --exclude='Applications/'
  )
  if $SECRETS_ACTIVE; then
    for sf in "${SECRETS_FILES[@]}"; do
      exclude_args+=(--exclude="$sf")
    done
  fi

  rsync -rl --delete "${exclude_args[@]}" "$clone/" "$original/"
}

handle_changes() {
  local clone="$1"
  local original="$2"

  if diff_changes "$clone" "$original" > /dev/null 2>&1; then
    info "files modified in sandbox:"
    diff_changes "$clone" "$original"
    echo ""

    if $AUTO_APPLY; then
      info "applying changes (--apply)..."
      apply_changes "$clone" "$original"
      info "done."
    elif $AUTO_DISCARD; then
      info "discarding changes (--discard)."
    else
      echo -ne "${CYAN}parcai:${RESET} apply changes to original project? [y/N] "
      read -r answer
      if [[ "$answer" =~ ^[Yy]$ ]]; then
        apply_changes "$clone" "$original"
        info "changes applied."
      else
        info "changes discarded."
      fi
    fi
  else
    info "no files modified."
  fi
}

# --- Parse Arguments ---

# Handle subcommands first
if [[ "${1:-}" == "init" ]]; then
  if [[ -f "$CONFIG_FILE" ]]; then
    warn ".parcai.json already exists"
    echo -ne "${CYAN}parcai:${RESET} overwrite? [y/N] "
    read -r answer
    [[ "$answer" =~ ^[Yy]$ ]] || exit 0
  fi
  generate_default_config > "$CONFIG_FILE"
  info "created .parcai.json"
  exit 0
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --allow)
      [[ $# -ge 2 ]] || die "--allow requires a path argument"
      EXTRA_ALLOW+=("$2"); shift 2 ;;
    --rw)
      [[ $# -ge 2 ]] || die "--rw requires a path argument"
      EXTRA_RW+=("$2"); shift 2 ;;
    --deny)
      [[ $# -ge 2 ]] || die "--deny requires a path argument"
      EXTRA_DENY+=("$2"); shift 2 ;;
    --no-network)
      NO_NETWORK=true; shift ;;
    --secrets)
      [[ $# -ge 2 ]] || die "--secrets requires a file argument"
      SECRETS_FILES+=("$2"); shift 2 ;;
    --secret-log)
      SECRET_LOG=true; shift ;;
    --apply)
      AUTO_APPLY=true; shift ;;
    --discard)
      AUTO_DISCARD=true; shift ;;
    --config)
      [[ $# -ge 2 ]] || die "--config requires a file argument"
      CONFIG_FILE="$2"; shift 2 ;;
    --shell)
      SHELL_ONLY=true; shift ;;
    --dry-run)
      DRY_RUN=true; shift ;;
    --verbose)
      VERBOSE=true; shift ;;
    --version)
      echo "parcai $VERSION"; exit 0 ;;
    --help|-h)
      usage; exit 0 ;;
    *)
      die "unknown option: $1" ;;
  esac
done

if $AUTO_APPLY && $AUTO_DISCARD; then
  die "--apply and --discard are mutually exclusive"
fi

# --- Main ---

# Create default .parcai.json if it doesn't exist
if [[ ! -f "$CONFIG_FILE" ]]; then
  info "no .parcai.json found — creating default config"
  generate_default_config > "$CONFIG_FILE"
fi

# Load config file (before platform dispatch, after CLI parsing)
# CLI flags have already set variables; load_config only fills unset values
load_config "$CONFIG_FILE"

# Only mask secrets files that actually exist in the project
local_secrets=()
for sf in "${SECRETS_FILES[@]}"; do
  if [[ -f "$sf" ]]; then
    local_secrets+=("$sf")
  fi
done
SECRETS_FILES=("${local_secrets[@]+"${local_secrets[@]}"}")

if $SECRET_LOG && [[ ${#SECRETS_FILES[@]} -eq 0 ]]; then
  die "--secret-log requires secrets files (none found in project)"
fi

# Validate domain config
if [[ ${#ALLOWED_DOMAINS[@]} -gt 0 && ${#BLOCKED_DOMAINS[@]} -gt 0 ]]; then
  die "allowed_domains and blocked_domains are mutually exclusive"
fi

check_platform

CWD="$(pwd)"
SESS_DIR=$(session_dir "$CWD")
EXIT_CODE=0

mkdir -p "$SESS_DIR"

if $VERBOSE; then
  info "platform: macOS"
  info "project:  $CWD"
  [[ -f "$CONFIG_FILE" ]] && info "config:   $CONFIG_FILE"
  [[ ${#ALLOWED_DOMAINS[@]} -gt 0 ]] && info "allowed domains: ${ALLOWED_DOMAINS[*]}"
  [[ ${#BLOCKED_DOMAINS[@]} -gt 0 ]] && info "blocked domains: ${BLOCKED_DOMAINS[*]}"
  [[ ${#ENV_OVERRIDES[@]} -gt 0 ]] && info "env overrides: ${ENV_OVERRIDES[*]}"
fi

run_macos "$CWD" "$SESS_DIR"

exit $EXIT_CODE
